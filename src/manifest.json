{
  "manifest_version": 3,
  "name": "PoE Ninja to Chronicles PoB Sharer",
  "version": "1.2.1",
  "description": "Adds a Share PoB button on poe.ninja for Path of Exile 1 & 2. Uploads PoB code to Chronicles and copies the share link to clipboard.",
  "homepage_url": "https://poe.jakeuj.com/",

  "host_permissions": [
    "https://poe.ninja/*",
    "https://poe2db.tw/*",
    "https://poedb.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://poe.ninja/poe2/profile/*/character/*",
        "https://poe.ninja/poe2/builds/*/character/*",
        "https://poe.ninja/poe1/profile/*/character/*",
        "https://poe.ninja/poe1/builds/*/character/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

